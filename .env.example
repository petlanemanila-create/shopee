SHOPEE_PARTNER_ID=your_partner_id
SHOPEE_PARTNER_KEY=your_partner_key
SHOPEE_SHOP_ID=your_shop_id

# Optional when you already have tokens. Otherwise use /auth/start after setting the app callback URL.
SHOPEE_ACCESS_TOKEN=
SHOPEE_REFRESH_TOKEN=

# Shopee production host. Use https://partner.test-stable.shopeemobile.com for sandbox.
SHOPEE_HOST=https://partner.shopeemobile.com

# Local dashboard settings.
PORT=3000
APP_BASE_URL=http://localhost:3000
